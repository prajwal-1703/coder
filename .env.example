# Hugging Face
HUGGING_FACE_HUB_TOKEN=your_huggingface_token_here
HF_ENDPOINT=https://hf-mirror.com

# --- Model Selection ---
# Uncomment ONE of the blocks below to choose your model:

# Option 1: Base Model (bitsandbytes INT8 - slower, already downloaded)
VLLM_MODEL_DIR=Qwen3-32B
VLLM_QUANTIZATION=bitsandbytes
VLLM_LOAD_FORMAT=bitsandbytes

# Option 2: AWQ Model (Fastest for A6000 - uncomment after running setup.sh again)
# VLLM_MODEL_DIR=Qwen3-32B-AWQ
# VLLM_QUANTIZATION=awq
# VLLM_LOAD_FORMAT=auto

# Embedding Model
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5

# Ports
VLLM_PORT=8000
WEBUI_PORT=3000
